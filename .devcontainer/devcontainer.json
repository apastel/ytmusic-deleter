{
  "name": "GPU Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/pdm:2": {}
  },
  "initializeCommand": "sh -c 'if [ -e /dev/dri ]; then echo \"GPU_DEVICE=/dev/dri\" > .devcontainer/gpu.env; elif [ -e /dev/dxg ]; then echo \"GPU_DEVICE=/dev/dxg\" > .devcontainer/gpu.env; else echo \"GPU_DEVICE=/dev/null\" > .devcontainer/gpu.env; fi'",
  "runArgs": [
    "--net=host",
    "-e", "DISPLAY=${localEnv:DISPLAY}",
    "--env-file", "${localWorkspaceFolder}/.devcontainer/gpu.env"
  ],
  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "LD_LIBRARY_PATH": "/usr/lib/wsl/lib"
  },
  "remoteEnv": {
    "DISPLAY": "${localEnv:DISPLAY}"
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "onCreateCommand": "./.devcontainer/on-create.sh",
  "postCreateCommand": ".devcontainer/post-create.sh"
}
